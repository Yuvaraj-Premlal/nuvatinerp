generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  industry    String?
  address     String?
  gstin       String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  users       User[]
  items       ItemMaster[]

  @@map("tenants")
}

model User {
  id          String   @id @default(uuid())
  tenant_id   String
  email       String
  password    String
  first_name  String
  last_name   String?
  role        String
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, email])
  @@map("users")
}

model ItemMaster {
  id              String      @id @default(uuid())
  tenant_id       String
  item_code       String
  item_name       String
  item_type       String
  unit_of_measure String
  item_category   String?
  description     String?
  is_active       Boolean     @default(true)
  created_at      DateTime    @default(now())
  updated_at      DateTime    @updatedAt

  tenant          Tenant      @relation(fields: [tenant_id], references: [id])
  pfep_detail     ItemPfepDetail?

  @@unique([tenant_id, item_code])
  @@map("item_master")
}

model ItemPfepDetail {
  id                    String   @id @default(uuid())
  tenant_id             String
  item_id               String   @unique
  gross_weight_kg       Float?
  net_weight_kg         Float?
  yield_percent         Float?
  storage_location      String?
  rack_address          String?
  zone                  String?
  reorder_point         Float?
  safety_stock          Float?
  order_quantity        Float?
  shelf_life_days       Int?
  abc_classification    String?
  constraint_flag       Boolean  @default(false)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  item                  ItemMaster @relation(fields: [item_id], references: [id])

  @@map("item_pfep_detail")
}
