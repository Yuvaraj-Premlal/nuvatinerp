generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  industry    String?
  address     String?
  gstin       String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  users              User[]
  items              ItemMaster[]
  suppliers          SupplierMaster[]
  machines           MachineMaster[]
  dies               DieMaster[]
  bom_headers        BomHeader[]
  purchase_orders    PurchaseOrder[]
  job_cards          JobCard[]
  sales_orders       SalesOrder[]

  @@map("tenants")
}

model User {
  id          String   @id @default(uuid())
  tenant_id   String
  email       String
  password    String
  first_name  String
  last_name   String?
  role        String
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, email])
  @@map("users")
}

model ItemMaster {
  id              String          @id @default(uuid())
  tenant_id       String
  item_code       String
  item_name       String
  item_type       String
  unit_of_measure String
  item_category   String?
  description     String?
  selling_price   Float?
  material_cost   Float?
  is_active       Boolean         @default(true)
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  tenant          Tenant              @relation(fields: [tenant_id], references: [id])
  pfep_detail     ItemPfepDetail?
  item_suppliers  ItemSupplierMap[]
  bom_headers          BomHeader[]
  bom_lines            BomLine[]
  fifo_overrides       FifoOverrideRequest[]
  issue_groups         MaterialIssueGroup[]
  po_lines        PurchaseOrderLine[]
  grn_lines       GrnLine[]
  stock_ledger    StockLedger[]
  material_issues MaterialIssue[]
  so_lines        SalesOrderLine[]
  dispatch_lines  DispatchLine[]
  quarantine_stock QuarantineStock[]

  @@unique([tenant_id, item_code])
  @@map("item_master")
}

model ItemPfepDetail {
  id                    String     @id @default(uuid())
  tenant_id             String
  item_id               String     @unique
  gross_weight_kg       Float?
  net_weight_kg         Float?
  yield_percent         Float?
  storage_location      String?
  rack_address          String?
  zone                  String?
  reorder_point         Float?
  safety_stock          Float?
  order_quantity        Float?
  shelf_life_days       Int?
  abc_classification    String?
  constraint_flag       Boolean    @default(false)
  created_at            DateTime   @default(now())
  updated_at            DateTime   @updatedAt

  item                  ItemMaster @relation(fields: [item_id], references: [id])

  @@map("item_pfep_detail")
}

model SupplierMaster {
  id              String   @id @default(uuid())
  tenant_id       String
  supplier_code   String
  supplier_name   String
  address         String?
  gstin           String?
  payment_terms   String?
  lead_time_days  Int?
  moq             Float?
  currency        String   @default("INR")
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant          Tenant            @relation(fields: [tenant_id], references: [id])
  item_suppliers  ItemSupplierMap[]
  purchase_orders PurchaseOrder[]

  @@unique([tenant_id, supplier_code])
  @@map("supplier_master")
}

model ItemSupplierMap {
  id              String         @id @default(uuid())
  tenant_id       String
  item_id         String
  supplier_id     String
  price           Float?
  moq             Float?
  lead_time_days  Int?
  is_preferred    Boolean        @default(false)
  effective_date  DateTime?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  item            ItemMaster     @relation(fields: [item_id], references: [id])
  supplier        SupplierMaster @relation(fields: [supplier_id], references: [id])

  @@unique([tenant_id, item_id, supplier_id])
  @@map("item_supplier_map")
}

model MachineMaster {
  id                    String   @id @default(uuid())
  tenant_id             String
  machine_code          String
  machine_name          String
  machine_type          String?
  capacity_tons         Float?
  rated_cycle_time_sec  Int?
  rated_shots_per_shift Int?
  is_constraint         Boolean  @default(false)
  oee_target_percent    Float?
  power_kw              Float?
  operators_required    Int?
  location              String?
  is_active             Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  tenant                Tenant             @relation(fields: [tenant_id], references: [id])
  dies                  DieMaster[]
  routing_operations    RoutingOperation[]
  downtime_logs         DowntimeLog[]
  constraint_configs    ConstraintConfig[]
  maintenance_wos       MaintenanceWorkOrder[]
  maintenance_schedules MaintenanceSchedule[]

  @@unique([tenant_id, machine_code])
  @@map("machine_master")
}

model DieMaster {
  id                    String   @id @default(uuid())
  tenant_id             String
  die_number            String
  die_name              String?
  item_id               String?
  cavity_count          Int      @default(1)
  design_life_shots     Int?
  current_shot_count    Int      @default(0)
  shots_at_last_pm      Int      @default(0)
  pm_interval_shots     Int?
  next_pm_due_shots     Int?
  die_owner             String?
  customer_id           String?
  current_status        String   @default("in_storage")
  repair_vendor         String?
  repair_lead_time_days Int?
  machine_id            String?
  location              String?
  is_active             Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  tenant                Tenant         @relation(fields: [tenant_id], references: [id])
  machine               MachineMaster? @relation(fields: [machine_id], references: [id])
  die_shot_logs         DieShotLog[]

  @@unique([tenant_id, die_number])
  @@map("die_master")
}

model DieShotLog {
  id               String    @id @default(uuid())
  tenant_id        String
  die_id           String
  shots_added      Int
  cumulative_shots Int
  job_card_id      String?
  logged_at        DateTime  @default(now())
  logged_by        String?

  die              DieMaster @relation(fields: [die_id], references: [id])

  @@map("die_shot_log")
}

model BomHeader {
  id              String    @id @default(uuid())
  tenant_id       String
  item_id         String
  bom_revision    String    @default("A")
  effective_date  DateTime?
  status          String    @default("draft")
  created_by      String?
  approved_by     String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant     @relation(fields: [tenant_id], references: [id])
  item            ItemMaster @relation(fields: [item_id], references: [id])
  bom_lines       BomLine[]

  @@unique([tenant_id, item_id, bom_revision])
  @@map("bom_header")
}

model BomLine {
  id                   String     @id @default(uuid())
  tenant_id            String
  bom_id               String
  component_item_id    String
  quantity_per         Float
  unit_of_measure      String?
  yield_factor         Float?
  scrap_percent        Float?
  line_type            String     @default("material")
  created_at           DateTime   @default(now())
  updated_at           DateTime   @updatedAt

  bom                  BomHeader  @relation(fields: [bom_id], references: [id])
  component_item       ItemMaster @relation(fields: [component_item_id], references: [id])

  @@map("bom_line")
}

model RoutingHeader {
  id               String    @id @default(uuid())
  tenant_id        String
  item_id          String
  routing_revision String    @default("A")
  effective_date   DateTime?
  status           String    @default("draft")
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  operations       RoutingOperation[]

  @@unique([tenant_id, item_id, routing_revision])
  @@map("routing_header")
}

model RoutingOperation {
  id                           String         @id @default(uuid())
  tenant_id                    String
  routing_id                   String
  operation_sequence           Int
  operation_name               String
  machine_id                   String?
  standard_time_sec            Int?
  setup_time_min               Int?
  is_constraint                Boolean        @default(false)
  is_pre_constraint_inspection Boolean        @default(false)
  operation_type               String         @default("production")
  is_outsourced                Boolean        @default(false)
  vendor_id                    String?
  operators_required           Int?
  created_at                   DateTime       @default(now())
  updated_at                   DateTime       @updatedAt

  routing                      RoutingHeader  @relation(fields: [routing_id], references: [id])
  machine                      MachineMaster? @relation(fields: [machine_id], references: [id])

  @@map("routing_operation")
}

model PurchaseOrder {
  id                     String    @id @default(uuid())
  tenant_id              String
  po_number              String
  supplier_id            String
  po_date                DateTime  @default(now())
  expected_delivery_date DateTime?
  status                 String    @default("draft")
  raised_by              String    @default("human")
  total_value            Float?
  currency               String    @default("INR")
  notes                  String?
  payment_terms          String?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt

  tenant                 Tenant             @relation(fields: [tenant_id], references: [id])
  supplier               SupplierMaster     @relation(fields: [supplier_id], references: [id])
  po_lines               PurchaseOrderLine[]
  grn_headers            GrnHeader[]
  revision_number        Int       @default(0)
  is_latest_revision     Boolean   @default(true)
  parent_po_id           String?
  cancellation_reason    String?
  cancelled_at           DateTime?
  cancelled_by           String?
  amendment_reason       String?
  closed_at              DateTime?
  closed_by              String?
  closure_notes          String?
  bill_status_at_closure String?
  short_closed           Boolean   @default(false)
  short_closed_qty       Float?
  short_close_reason     String?

  @@unique([tenant_id, po_number, revision_number])
  @@map("purchase_order")
}

model PurchaseOrderLine {
  id                 String        @id @default(uuid())
  tenant_id          String
  po_id              String
  item_id            String
  quantity_ordered   Float
  unit_price         Float?
  uom                String?
  quantity_received  Float         @default(0)
  quantity_pending   Float?
  created_at         DateTime      @default(now())
  updated_at         DateTime      @updatedAt

  po                 PurchaseOrder @relation(fields: [po_id], references: [id])
  item               ItemMaster    @relation(fields: [item_id], references: [id])

  @@map("purchase_order_line")
}

model GrnHeader {
  id                  String         @id @default(uuid())
  tenant_id           String
  grn_number          String
  po_id               String?
  supplier_id         String?
  received_date       DateTime       @default(now())
  received_by         String?
  vehicle_number      String?
  supplier_dc_number  String?
  created_at          DateTime       @default(now())
  updated_at          DateTime       @updatedAt

  is_reversed         Boolean   @default(false)
  reversal_reason     String?
  reversed_at         DateTime?
  po                  PurchaseOrder? @relation(fields: [po_id], references: [id])
  grn_lines           GrnLine[]

  @@unique([tenant_id, grn_number])
  @@map("grn_header")
}

model GrnLine {
  id                String     @id @default(uuid())
  tenant_id         String
  grn_id            String
  item_id           String
  quantity_received Float
  accepted_qty      Float?
  rejected_qty      Float?
  rejection_reason  String?
  batch_number      String?
  lot_number        String?
  unit_price        Float?
  created_at        DateTime   @default(now())
  updated_at        DateTime   @updatedAt

  grn               GrnHeader  @relation(fields: [grn_id], references: [id])
  item              ItemMaster @relation(fields: [item_id], references: [id])

  @@map("grn_line")
}

model StockLedger {
  id               String     @id @default(uuid())
  tenant_id        String
  item_id          String
  transaction_type String
  quantity         Float
  unit_cost        Float?
  reference_type   String?
  reference_id     String?
  location         String?
  batch_number     String?
  lot_number       String?
  transacted_at    DateTime   @default(now())
  transacted_by    String?
  adjustment_reason String?

  item             ItemMaster @relation(fields: [item_id], references: [id])

  @@map("stock_ledger")
}

model JobCard {
  id                    String    @id @default(uuid())
  tenant_id             String
  job_number            String
  item_id               String?
  bom_id                String?
  routing_id            String?
  machine_id            String?
  die_id                String?
  planned_quantity      Float
  actual_quantity_good  Float     @default(0)
  shift                 String?
  planned_date          DateTime?
  actual_start          DateTime?
  actual_end            DateTime?
  status                String    @default("planned")
  created_by            String?
  released_by           String?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  tenant                Tenant          @relation(fields: [tenant_id], references: [id])
  shot_logs             ShotLog[]
  downtime_logs         DowntimeLog[]
  material_issues       MaterialIssue[]
  issue_groups          MaterialIssueGroup[]
  rejection_logs        RejectionLog[]
  job_operations        JobCardOperation[]

  @@unique([tenant_id, job_number])
  @@map("job_card")
}

model ShotLog {
  id                String    @id @default(uuid())
  tenant_id         String
  job_id            String
  shot_number       Int
  shot_result       String    @default("good")
  rejection_reason  String?
  logged_at         DateTime  @default(now())
  logged_by         String?

  job               JobCard   @relation(fields: [job_id], references: [id])

  @@map("shot_log")
}

model DowntimeLog {
  id                String         @id @default(uuid())
  tenant_id         String
  job_id            String
  machine_id        String?
  start_time        DateTime
  end_time          DateTime?
  duration_min      Int?
  downtime_category String         @default("unplanned")
  reason_code       String?
  reason_detail     String?
  logged_by         String?
  created_at        DateTime       @default(now())

  job               JobCard        @relation(fields: [job_id], references: [id])
  machine           MachineMaster? @relation(fields: [machine_id], references: [id])

  @@map("downtime_log")
}

model MaterialIssueGroup {
  id               String          @id @default(uuid())
  tenant_id        String
  slip_number      String
  job_id           String
  item_id          String
  planned_qty      Float?
  total_issued_qty Float
  issued_by        String?
  issued_at        DateTime        @default(now())
  is_fifo_override Boolean         @default(false)
  job              JobCard         @relation(fields: [job_id], references: [id])
  item             ItemMaster      @relation(fields: [item_id], references: [id])
  lines            MaterialIssue[]
  @@map("material_issue_group")
}

model MaterialIssue {
  id           String     @id @default(uuid())
  tenant_id    String
  job_id       String
  item_id      String
  planned_qty  Float?
  issued_qty   Float
  returned_qty Float      @default(0)
  issued_at    DateTime   @default(now())
  issued_by    String?
  location     String?

  batch_number         String?
  grn_id               String?
  fifo_override        Boolean  @default(false)
  override_reason      String?
  override_approved_by String?
  override_approved_at DateTime?
  override_request_id  String?
  group_id             String?

  job          JobCard             @relation(fields: [job_id], references: [id])
  item         ItemMaster          @relation(fields: [item_id], references: [id])
  group        MaterialIssueGroup? @relation(fields: [group_id], references: [id])

  @@map("material_issue")
}

model InspectionHeader {
  id               String    @id @default(uuid())
  tenant_id        String
  job_id           String?
  inspection_type  String
  inspection_date  DateTime  @default(now())
  inspector_id     String?
  result           String    @default("pending")
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  inspection_lines InspectionLine[]
  rejection_logs   RejectionLog[]

  @@map("inspection_header")
}

model InspectionLine {
  id                  String           @id @default(uuid())
  tenant_id           String
  inspection_id       String
  parameter_name      String
  specification_min   Float?
  specification_max   Float?
  unit                String?
  actual_value        Float?
  result              String           @default("pending")
  created_at          DateTime         @default(now())

  inspection          InspectionHeader @relation(fields: [inspection_id], references: [id])

  @@map("inspection_line")
}

model RejectionLog {
  id                  String            @id @default(uuid())
  tenant_id           String
  job_id              String?
  item_id             String?
  inspection_id       String?
  quantity_rejected   Float
  rejection_stage     String?
  defect_code         String?
  defect_description  String?
  die_id              String?
  machine_id          String?
  alloy_lot           String?
  disposition         String            @default("scrap")
  logged_at           DateTime          @default(now())
  logged_by           String?

  job                 JobCard?          @relation(fields: [job_id], references: [id])
  inspection          InspectionHeader? @relation(fields: [inspection_id], references: [id])

  @@map("rejection_log")
}

model SalesOrder {
  id             String    @id @default(uuid())
  tenant_id      String
  so_number      String
  customer_id    String?
  customer_name  String?
  order_date     DateTime  @default(now())
  delivery_date  DateTime?
  status         String    @default("open")
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  tenant         Tenant           @relation(fields: [tenant_id], references: [id])
  customer       CustomerMaster?  @relation(fields: [customer_id], references: [id])
  so_lines       SalesOrderLine[]
  dispatches     DispatchHeader[]

  @@unique([tenant_id, so_number])
  @@map("sales_order")
}

model SalesOrderLine {
  id                   String     @id @default(uuid())
  tenant_id            String
  so_id                String
  item_id              String
  quantity_ordered     Float
  quantity_dispatched  Float      @default(0)
  quantity_pending     Float?
  unit_price           Float?
  uom                  String?
  created_at           DateTime   @default(now())
  updated_at           DateTime   @updatedAt

  so                   SalesOrder @relation(fields: [so_id], references: [id])
  item                 ItemMaster @relation(fields: [item_id], references: [id])
  dispatch_lines       DispatchLine[]

  @@map("sales_order_line")
}

model DispatchHeader {
  id               String      @id @default(uuid())
  tenant_id        String
  dispatch_number  String
  so_id            String?
  dispatch_date    DateTime    @default(now())
  dispatched_by    String?
  vehicle_number   String?
  transporter      String?
  challan_number   String?
  eway_bill_number String?
  status           String      @default("draft")
  created_at       DateTime    @default(now())
  updated_at       DateTime    @updatedAt

  so               SalesOrder? @relation(fields: [so_id], references: [id])
  dispatch_lines   DispatchLine[]

  @@unique([tenant_id, dispatch_number])
  @@map("dispatch_header")
}

model DispatchLine {
  id                   String          @id @default(uuid())
  tenant_id            String
  dispatch_id          String
  item_id              String
  so_line_id           String?
  quantity_dispatched  Float
  batch_number         String?
  pack_count           Int?
  pieces_per_pack      Int?
  created_at           DateTime        @default(now())

  dispatch             DispatchHeader  @relation(fields: [dispatch_id], references: [id])
  item                 ItemMaster      @relation(fields: [item_id], references: [id])
  so_line              SalesOrderLine? @relation(fields: [so_line_id], references: [id])

  @@map("dispatch_line")
}

model ConstraintConfig {
  id                    String        @id @default(uuid())
  tenant_id             String
  machine_id            String
  is_active_constraint  Boolean       @default(true)
  buffer_target_hours   Float?
  throughput_per_hour   Float?
  effective_from        DateTime?
  effective_to          DateTime?
  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt

  machine               MachineMaster @relation(fields: [machine_id], references: [id])

  @@map("constraint_config")
}

model AgentActionLog {
  id              String    @id @default(uuid())
  tenant_id       String
  agent_type      String
  action_taken    String
  reference_type  String?
  reference_id    String?
  triggered_by    String    @default("system")
  status          String    @default("pending_approval")
  actioned_by     String?
  actioned_at     DateTime?
  created_at      DateTime  @default(now())

  @@map("agent_action_log")
}

model SystemAlert {
  id              String    @id @default(uuid())
  tenant_id       String
  alert_type      String
  severity        String    @default("info")
  message         String
  reference_type  String?
  reference_id    String?
  is_read         Boolean   @default(false)
  is_resolved     Boolean   @default(false)
  created_at      DateTime  @default(now())
  resolved_at     DateTime?
  resolved_by     String?

  @@map("system_alert")
}

model VendorMaster {
  id                String   @id @default(uuid())
  tenant_id         String
  vendor_code       String
  vendor_name       String
  address           String?
  gstin             String?
  operation_types   String?
  payment_terms     String?
  lead_time_days    Int?
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  job_work_orders   JobWorkOrder[]

  @@unique([tenant_id, vendor_code])
  @@map("vendor_master")
}

model JobWorkOrder {
  id                    String    @id @default(uuid())
  tenant_id             String
  jwo_number            String
  job_card_id           String?
  vendor_id             String
  item_id               String?
  operation_id          String?
  quantity_sent         Float
  outward_challan       String?
  expected_return_date  DateTime?
  job_work_charge       Float?
  status                String    @default("draft")
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  vendor                VendorMaster      @relation(fields: [vendor_id], references: [id])
  receipts              JobWorkReceipt[]

  @@unique([tenant_id, jwo_number])
  @@map("job_work_order")
}

model JobWorkReceipt {
  id                      String       @id @default(uuid())
  tenant_id               String
  jwr_number              String
  jwo_id                  String
  quantity_received       Float
  accepted_qty            Float?
  rejected_qty            Float?
  rejection_reason        String?
  inward_challan          String?
  job_work_charge_billed  Float?
  received_at             DateTime     @default(now())
  received_by             String?

  jwo                     JobWorkOrder @relation(fields: [jwo_id], references: [id])

  @@unique([tenant_id, jwr_number])
  @@map("job_work_receipt")
}

model CustomerMaster {
  id              String   @id @default(uuid())
  tenant_id       String
  customer_code   String
  customer_name   String
  address         String?
  gstin           String?
  contact_person  String?
  contact_phone   String?
  payment_terms   String?
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  sales_orders    SalesOrder[]

  @@unique([tenant_id, customer_code])
  @@map("customer_master")
}

model JobCardOperation {
  id                  String    @id @default(uuid())
  tenant_id           String
  job_id              String
  operation_id        String?
  operation_sequence  Int
  operation_name      String
  operation_type      String    @default("production")
  is_outsourced       Boolean   @default(false)
  vendor_id           String?
  machine_id          String?
  operator_id         String?
  status              String    @default("pending")
  planned_start       DateTime?
  actual_start        DateTime?
  actual_end          DateTime?
  notes               String?
  created_at          DateTime  @default(now())
  updated_at          DateTime  @updatedAt

  job                 JobCard   @relation(fields: [job_id], references: [id])

  @@map("job_card_operation")
}

model BufferLog {
  id                    String   @id @default(uuid())
  tenant_id             String
  machine_id            String
  buffer_hours          Float
  buffer_target_hours   Float
  buffer_status         String
  logged_at             DateTime @default(now())

  @@map("buffer_log")
}

model CostConfig {
  id              String   @id @default(uuid())
  tenant_id       String
  config_key      String
  config_value    Float
  description     String?
