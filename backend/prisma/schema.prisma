generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  industry    String?
  address     String?
  gstin       String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  users       User[]

  @@map("tenants")
}

model User {
  id          String   @id @default(uuid())
  tenant_id   String
  email       String
  password    String
  first_name  String
  last_name   String?
  role        String
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, email])
  @@map("users")
}
