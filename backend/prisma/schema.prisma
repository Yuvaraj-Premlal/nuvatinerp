generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id          String   @id @default(uuid())
  name        String
  code        String   @unique
  industry    String?
  address     String?
  gstin       String?
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  users             User[]
  items             ItemMaster[]
  suppliers         SupplierMaster[]
  machines          MachineMaster[]
  dies              DieMaster[]
  bom_headers       BomHeader[]

  @@map("tenants")
}

model User {
  id          String   @id @default(uuid())
  tenant_id   String
  email       String
  password    String
  first_name  String
  last_name   String?
  role        String
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenant_id], references: [id])

  @@unique([tenant_id, email])
  @@map("users")
}

model ItemMaster {
  id              String          @id @default(uuid())
  tenant_id       String
  item_code       String
  item_name       String
  item_type       String
  unit_of_measure String
  item_category   String?
  description     String?
  is_active       Boolean         @default(true)
  created_at      DateTime        @default(now())
  updated_at      DateTime        @updatedAt

  tenant          Tenant          @relation(fields: [tenant_id], references: [id])
  pfep_detail     ItemPfepDetail?
  item_suppliers  ItemSupplierMap[]
  bom_headers     BomHeader[]
  bom_lines       BomLine[]

  @@unique([tenant_id, item_code])
  @@map("item_master")
}

model ItemPfepDetail {
  id                    String     @id @default(uuid())
  tenant_id             String
  item_id               String     @unique
  gross_weight_kg       Float?
  net_weight_kg         Float?
  yield_percent         Float?
  storage_location      String?
  rack_address          String?
  zone                  String?
  reorder_point         Float?
  safety_stock          Float?
  order_quantity        Float?
  shelf_life_days       Int?
  abc_classification    String?
  constraint_flag       Boolean    @default(false)
  created_at            DateTime   @default(now())
  updated_at            DateTime   @updatedAt

  item                  ItemMaster @relation(fields: [item_id], references: [id])

  @@map("item_pfep_detail")
}

model SupplierMaster {
  id              String   @id @default(uuid())
  tenant_id       String
  supplier_code   String
  supplier_name   String
  address         String?
  gstin           String?
  payment_terms   String?
  lead_time_days  Int?
  moq             Float?
  currency        String   @default("INR")
  is_active       Boolean  @default(true)
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenant_id], references: [id])
  item_suppliers  ItemSupplierMap[]

  @@unique([tenant_id, supplier_code])
  @@map("supplier_master")
}

model ItemSupplierMap {
  id              String         @id @default(uuid())
  tenant_id       String
  item_id         String
  supplier_id     String
  price           Float?
  moq             Float?
  lead_time_days  Int?
  is_preferred    Boolean        @default(false)
  effective_date  DateTime?
  created_at      DateTime       @default(now())
  updated_at      DateTime       @updatedAt

  item            ItemMaster     @relation(fields: [item_id], references: [id])
  supplier        SupplierMaster @relation(fields: [supplier_id], references: [id])

  @@unique([tenant_id, item_id, supplier_id])
  @@map("item_supplier_map")
}

model MachineMaster {
  id                    String   @id @default(uuid())
  tenant_id             String
  machine_code          String
  machine_name          String
  machine_type          String?
  capacity_tons         Float?
  rated_cycle_time_sec  Int?
  rated_shots_per_shift Int?
  is_constraint         Boolean  @default(false)
  oee_target_percent    Float?
  location              String?
  is_active             Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  tenant                Tenant   @relation(fields: [tenant_id], references: [id])
  dies                  DieMaster[]
  routing_operations    RoutingOperation[]

  @@unique([tenant_id, machine_code])
  @@map("machine_master")
}

model DieMaster {
  id                    String   @id @default(uuid())
  tenant_id             String
  die_number            String
  die_name              String?
  item_id               String?
  cavity_count          Int      @default(1)
  design_life_shots     Int?
  current_shot_count    Int      @default(0)
  shots_at_last_pm      Int      @default(0)
  pm_interval_shots     Int?
  next_pm_due_shots     Int?
  die_owner             String?
  customer_id           String?
  current_status        String   @default("in_storage")
  repair_vendor         String?
  repair_lead_time_days Int?
  machine_id            String?
  location              String?
  is_active             Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  tenant                Tenant         @relation(fields: [tenant_id], references: [id])
  machine               MachineMaster? @relation(fields: [machine_id], references: [id])

  @@unique([tenant_id, die_number])
  @@map("die_master")
}

model BomHeader {
  id              String    @id @default(uuid())
  tenant_id       String
  item_id         String
  bom_revision    String    @default("A")
  effective_date  DateTime?
  status          String    @default("draft")
  created_by      String?
  approved_by     String?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt

  tenant          Tenant     @relation(fields: [tenant_id], references: [id])
  item            ItemMaster @relation(fields: [item_id], references: [id])
  bom_lines       BomLine[]

  @@unique([tenant_id, item_id, bom_revision])
  @@map("bom_header")
}

model BomLine {
  id                   String     @id @default(uuid())
  tenant_id            String
  bom_id               String
  component_item_id    String
  quantity_per         Float
  unit_of_measure      String?
  yield_factor         Float?
  scrap_percent        Float?
  line_type            String     @default("material")
  created_at           DateTime   @default(now())
  updated_at           DateTime   @updatedAt

  bom                  BomHeader  @relation(fields: [bom_id], references: [id])
  component_item       ItemMaster @relation(fields: [component_item_id], references: [id])

  @@map("bom_line")
}

model RoutingHeader {
  id               String    @id @default(uuid())
  tenant_id        String
  item_id          String
  routing_revision String    @default("A")
  effective_date   DateTime?
  status           String    @default("draft")
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  operations       RoutingOperation[]

  @@unique([tenant_id, item_id, routing_revision])
  @@map("routing_header")
}

model RoutingOperation {
  id                          String         @id @default(uuid())
  tenant_id                   String
  routing_id                  String
  operation_sequence          Int
  operation_name              String
  machine_id                  String?
  standard_time_sec           Int?
  setup_time_min              Int?
  is_constraint               Boolean        @default(false)
  is_pre_constraint_inspection Boolean       @default(false)
  created_at                  DateTime       @default(now())
  updated_at                  DateTime       @updatedAt

  routing                     RoutingHeader  @relation(fields: [routing_id], references: [id])
  machine                     MachineMaster? @relation(fields: [machine_id], references: [id])

  @@map("routing_operation")
}
